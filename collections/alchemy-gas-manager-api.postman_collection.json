        {
          "id": "3d503dae-22c9-4d35-bbc7-696642da0679",
          "name": "Alchemy Gas Manager Sponsor User Operation",
          "request": {
            "name": "Alchemy Gas Manager Sponsor User Operation",
            "description": {
              "content": "Submits a user operation for gas sponsorship via the ERC-4337 paymaster. Returns a signed paymaster response that the bundler uses to cover gas fees on behalf of the user, enabling gasless transactions.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "sponsorUserOperation"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": {
              "type": "apikey",
              "apikey": [
                {
                  "key": "key",
                  "value": "X-Alchemy-Token"
                },
                {
                  "key": "value",
                  "value": "{{apiKey}}"
                },
                {
                  "key": "in",
                  "value": "header"
